# SQLite file path for inventory and order data.
STOCKQUERY_DB_PATH=./agent_inventory.db

# Persistent Chroma directory for knowledge-base embeddings.
STOCKQUERY_CHROMA_PATH=./chroma_db

# OpenAI-compatible base URL, typically an Ollama endpoint.
OPENAI_BASE_URL=http://localhost:11434/v1

# API key sent to the OpenAI-compatible client.
OPENAI_API_KEY=ollama

# Chat model used by the inventory agent.
STOCKQUERY_LLM_MODEL=qwen2.5:1.5b

# Maximum time to wait for the local LLM before falling back to a deterministic verified response.
STOCKQUERY_LLM_TIMEOUT_SECONDS=12

# Default threshold for low-stock alerts and tool routing.
STOCKQUERY_LOW_STOCK_THRESHOLD=10

# Number of chat turns retained per session.
STOCKQUERY_SESSION_HISTORY_LIMIT=12

# Comma-separated frontend origins allowed by CORS.
STOCKQUERY_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://localhost:8081
